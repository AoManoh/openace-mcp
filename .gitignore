# Local environment and secrets
.env
.env.*
!.env.example

# Dependency and build outputs
node_modules/
dist/
build/
coverage/
.cache/
.turbo/
/openace-mcp
/openace-daemon

# Runtime logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Root-level local helper scripts are private by default.
# Reusable public automation should live under the owning skill directory.
/AGENTS.md
/scripts/
/skills/
/.augmentignore

# Private governance outputs.
# Local reports, work logs, requirements, references, debug notes and review
# artifacts stay private by default. Only add a precise ! exception when a
# document must be public-read and the user explicitly approves it.
/docs/
