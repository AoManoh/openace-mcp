# Local environment and secrets
.env
.env.*
!.env.example

# Dependency and build outputs
node_modules/
dist/
build/
coverage/
.cache/
.turbo/

# Runtime logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Root-level local helper scripts are private by default.
# Reusable public automation should live under the owning skill directory.
/scripts/

# Private governance outputs.
# Keep docs/ as a public template skeleton, but do not publish local reports,
# work logs, references, PRDs, debug notes, or review artifacts by default.
# To intentionally publish a docs artifact, add an explicit ! exception below.
/docs/**
!/docs/
!/docs/**/
!/docs/**/.gitkeep
!/docs/_fragments/
!/docs/_fragments/**
!/docs/requirements/2026-05-05-project-kickoff.md
!/docs/references/2026-05-05-openace-context-engine.md
!/docs/work-logs/2026-05-05.md
