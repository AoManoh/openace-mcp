# Upstream Context Engine authentication. Choose one authentication mode.

# Mode 1: full session JSON, preferred for non-interactive MCP usage.
AUGMENT_SESSION_AUTH=

# Mode 2: token + tenant URL.
AUGMENT_TOKEN=
AUGMENT_TENANT=

# Mode 3: explicit local session file.
OPENACE_SESSION_FILE=

# Experimental advanced multi-provider profile file. Leave empty for the
# recommended single-tenant path. When set, it replaces the single legacy
# credential chain above and lets tools select a provider_profile_id explicitly.
OPENACE_PROFILES_FILE=

# Local runtime settings.
# Use a separate cache dir when validating different accounts or tenants.
OPENACE_MODE=auto
OPENACE_CACHE_DIR=
OPENACE_CACHE_NAMESPACE=default
OPENACE_DAEMON_ADDR=
OPENACE_DAEMON_LISTEN_ADDR=127.0.0.1:8765
OPENACE_DAEMON_TOKEN=
OPENACE_DAEMON_START_TIMEOUT=10s
OPENACE_TASK_WORKERS=4
OPENACE_TASK_STORE_DIR=
OPENACE_ALLOW_REMOTE_DAEMON=
OPENACE_LOG_LEVEL=info

# Large workspace tuning.
OPENACE_RETRIEVAL_TIMEOUT=90s
OPENACE_RETRIEVAL_CONCURRENCY_PER_PROVIDER=8
OPENACE_UPLOAD_BATCH_BYTES=1048576
OPENACE_FIND_MISSING_BATCH_SIZE=1000
OPENACE_MAX_FILE_BYTES=1048576
